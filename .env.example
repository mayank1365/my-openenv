# ─── LLM API ─────────────────────────────────────────────────────────────────
# During hackathon validation, API_BASE_URL and API_KEY are injected automatically
# by the LiteLLM proxy. DO NOT set API_KEY here for submissions.
#
# For local development, set HF_TOKEN to your Groq or OpenAI key:
#   Groq:   https://console.groq.com/keys
#   OpenAI: https://platform.openai.com/api-keys
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile
HF_TOKEN=your_api_key_here

# API_KEY is injected at runtime by the hackathon validator — do not set this
# in .env for submissions. For local dev you can set it to your API key:
# API_KEY=your_api_key_here

# ─── Environment Server ───────────────────────────────────────────────────────
ENV_URL=https://hollow-abyss-my-env.hf.space

# Optional - if using from_docker_image()
# LOCAL_IMAGE_NAME=pipeline-repair
